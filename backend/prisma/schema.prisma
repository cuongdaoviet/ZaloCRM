generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Top-level org — every resource is scoped to an org
model Organization {
  id        String   @id @default(uuid())
  name      String
  // ─── Feature 0040 — Lead scoring config ────────────────────────────────────
  // Per-org override for the rules-based lead scoring formula. When null the
  // service falls back to baked-in defaults (BR-0007). Schema enforced at the
  // application layer (see lead-score-service.parseLeadScoreConfig).
  // ────────────────────────────────────────────────────────────────────────────
  leadScoreConfig Json?   @map("lead_score_config")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  teams         Team[]
  users         User[]
  zaloAccounts  ZaloAccount[]
  contacts      Contact[]
  conversations Conversation[]
  appointments  Appointment[]
  activityLogs  ActivityLog[]
  dailyStats    DailyMessageStat[]
  settings      AppSetting[]
  orders        Order[]
  quickReplies  QuickReply[]
  campaigns     Campaign[]
  keywordRules  KeywordRule[]
  webhookDeliveries WebhookDelivery[]
  pinnedConversations PinnedConversation[]
  duplicateGroups   DuplicateGroup[]
  // Feature 0019 — CRM tags
  crmTags       CrmTag[]
  crmTagGroups  CrmTagGroup[]
  zaloLabels    ZaloLabel[]
  // Feature 0037 — Workflow automation engine
  workflowDefinitions WorkflowDefinition[]
  workflowExecutions  WorkflowExecution[]
  // Feature 0036 — AI reply suggestions (BYOK)
  aiConfig            AiConfig?
  aiSuggestionLogs    AiSuggestionLog[]

  @@map("organizations")
}

// Team groups within an organization
model Team {
  id        String   @id @default(uuid())
  orgId     String   @map("org_id")
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  users User[]

  @@map("teams")
}

// CRM user with role-based access
model User {
  id           String   @id @default(uuid())
  orgId        String   @map("org_id")
  teamId       String?  @map("team_id")
  email        String   @unique
  passwordHash String   @map("password_hash")
  fullName     String   @map("full_name")
  role         String   @default("member") // owner, admin, member
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  org              Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  team             Team?               @relation(fields: [teamId], references: [id])
  zaloAccounts     ZaloAccount[]
  zaloAccess       ZaloAccountAccess[]
  assignedContacts Contact[]           @relation("AssignedContacts")
  appointments       Appointment[]
  repliedMessages    Message[]           @relation("RepliedMessages")
  activityLogs       ActivityLog[]
  createdOrders      Order[]             @relation("CreatedOrders")
  quickReplies       QuickReply[]        @relation("CreatedQuickReplies")
  createdCampaigns   Campaign[]          @relation("CreatedCampaigns")
  keywordRuleAssigns KeywordRule[]       @relation("KeywordRuleAssign")
  conversationNotes  ConversationNote[]  @relation("ConversationNotes")
  preferences        UserPreference[]
  createdFriendshipAttempts FriendshipAttempt[] @relation("CreatedFriendshipAttempts")
  contactTagsAdded   ContactTag[]        @relation("ContactTagsAdded")

  @@map("users")
}

// Zalo account linked to a user (one user may own multiple Zalo accounts)
model ZaloAccount {
  id              String    @id @default(uuid())
  orgId           String    @map("org_id")
  ownerUserId     String    @map("owner_user_id")
  zaloUid         String?   @unique @map("zalo_uid")
  displayName     String?   @map("display_name")
  avatarUrl       String?   @map("avatar_url")
  phone           String?
  status          String    @default("disconnected") // connected, disconnected, qr_pending
  sessionData     Json?     @map("session_data")
  // Feature 0035 — Per-account proxy config.
  // NULL = no proxy (direct connect). Accepted schemes: http, https, socks, socks5.
  // Stored normalized (socks→socks5, trailing slash stripped).
  proxyUrl        String?   @map("proxy_url")
  lastConnectedAt DateTime? @map("last_connected_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  org           Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  owner         User                @relation(fields: [ownerUserId], references: [id])
  access        ZaloAccountAccess[]
  conversations Conversation[]
  dailyStats    DailyMessageStat[]
  autoReplyRule AutoReplyRule?
  campaigns     Campaign[]
  pinnedConversations PinnedConversation[]
  friendshipAttempts FriendshipAttempt[]
  friends       Friend[]
  zaloLabels    ZaloLabel[]
  crmTagGroups  CrmTagGroup[]

  @@map("zalo_accounts")
}

// ACL: which users can access which Zalo accounts
model ZaloAccountAccess {
  id            String   @id @default(uuid())
  zaloAccountId String   @map("zalo_account_id")
  userId        String   @map("user_id")
  permission    String   @default("read") // read, chat, admin
  createdAt     DateTime @default(now()) @map("created_at")

  zaloAccount ZaloAccount @relation(fields: [zaloAccountId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([zaloAccountId, userId])
  @@map("zalo_account_access")
}

// CRM contact record — generic pipeline with status field
model Contact {
  id               String    @id @default(uuid())
  orgId            String    @map("org_id")
  zaloUid          String?   @map("zalo_uid")
  // Feature 0034 — canonical Zalo identifier that survives nick/account changes.
  // Filled in by the inbound message pipeline once `getUserInfo` returns a non-empty
  // `globalId`. Indexed for the new `globalId_exact` duplicate detection strategy.
  zaloGlobalId     String?   @map("zalo_global_id")
  phone            String?
  email            String?   @map("email")
  fullName         String?   @map("full_name")
  // Feature 0024 — Zalo display name auto-synced from inbound messages.
  // Never overwritten by rep edits (fullName is the CRM-editable name).
  // Display rule: show as muted secondary when it differs from fullName.
  zaloDisplayName  String?   @map("zalo_display_name")
  avatarUrl        String?   @map("avatar_url")
  source           String?   // FB, TT, GT, CN, etc.
  sourceDate       DateTime? @map("source_date")
  firstContactDate DateTime? @map("first_contact_date")
  status           String?   @default("new") // new/contacted/interested/converted/lost
  nextAppointment  DateTime? @map("next_appointment")
  assignedUserId   String?   @map("assigned_user_id")
  notes            String?
  // Feature 0019 Phase C — legacy `tags Json` column dropped. Tags now live
  // exclusively in the `ContactTag` junction → `CrmTag` rows.
  metadata         Json      @default("{}")
  // ── Feature 0018 — duplicate merge bookkeeping ─────────────────────────────
  // Set when this contact has been merged INTO another (the primary). Once
  // set, list/pipeline endpoints filter it out by default.
  mergedIntoId     String?   @map("merged_into_id")
  mergedAt         DateTime? @map("merged_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  org             Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  assignedUser    User?            @relation("AssignedContacts", fields: [assignedUserId], references: [id])
  conversations   Conversation[]
  appointments    Appointment[]
  orders          Order[]
  campaignTargets CampaignTarget[]
  mergedInto      Contact?         @relation("ContactMerges", fields: [mergedIntoId], references: [id])
  mergedChildren  Contact[]        @relation("ContactMerges")
  attempts        FriendshipAttempt[]
  friends         Friend[]
  contactTags     ContactTag[]
  workflowExecutions WorkflowExecution[]

  @@index([orgId, mergedIntoId])
  // Feature 0034 — composite index powers fast `globalId_exact` lookup in the
  // duplicate detector and any future per-org globalId queries.
  @@index([orgId, zaloGlobalId])
  @@map("contacts")
}

// A chat thread between a Zalo account and a contact (or group)
model Conversation {
  id               String    @id @default(uuid())
  orgId            String    @map("org_id")
  zaloAccountId    String    @map("zalo_account_id")
  contactId        String?   @map("contact_id")
  threadType       String    @default("user") // user, group
  externalThreadId String?   @map("external_thread_id")
  lastMessageAt    DateTime? @map("last_message_at")
  unreadCount      Int       @default(0) @map("unread_count")
  isReplied        Boolean   @default(true) @map("is_replied")
  // Feature 0023 — Hide / archive into a separate tab.
  // "main" = visible in the default Inbox tab.
  // "other" = hidden inside the "Khác" tab.
  // Existing rows default to "main"; matches ZaloCRM-3.0 wire format.
  tab              String    @default("main") @map("tab")
  createdAt        DateTime  @default(now()) @map("created_at")

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  zaloAccount ZaloAccount  @relation(fields: [zaloAccountId], references: [id], onDelete: Cascade)
  contact     Contact?     @relation(fields: [contactId], references: [id])
  messages    Message[]
  orders      Order[]
  notes       ConversationNote[]
  pin         PinnedConversation?

  @@unique([zaloAccountId, externalThreadId])
  // Feature 0023 — speeds up `WHERE orgId+tab ORDER BY lastMessageAt DESC` queries
  // used by the conversation list when filtering by tab.
  @@index([orgId, tab, lastMessageAt(sort: Desc)])
  @@map("conversations")
}

// Individual message within a conversation
model Message {
  id              String    @id @default(uuid())
  conversationId  String    @map("conversation_id")
  zaloMsgId       String?   @map("zalo_msg_id")
  senderType      String    @map("sender_type") // self, contact
  senderUid       String?   @map("sender_uid")
  senderName      String?   @map("sender_name")
  content         String?
  contentType     String    @default("text") @map("content_type") // text, image, file, sticker, voice, video, link
  attachments     Json      @default("[]")
  isDeleted       Boolean   @default(false) @map("is_deleted")
  deletedAt       DateTime? @map("deleted_at")
  sentAt          DateTime  @map("sent_at")
  repliedByUserId String?   @map("replied_by_user_id")
  // Feature 0031 — Reply / quote message. Self-reference FK; SET NULL when
  // the referenced message is deleted (BR-0002) so existing replies are not
  // cascaded but lose their link. quotedMeta JSON in `content` (out of band)
  // handles inbound quotes whose target is not in our DB (BR-0006).
  replyToMessageId String?  @map("reply_to_message_id")
  createdAt       DateTime  @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  repliedBy    User?        @relation("RepliedMessages", fields: [repliedByUserId], references: [id])
  // Feature 0021 — emoji reactions persisted per (message, reactor)
  reactions    MessageReaction[]
  // Feature 0031 — self-referencing reply chain
  replyToMessage Message?   @relation("MessageReply", fields: [replyToMessageId], references: [id], onDelete: SetNull)
  replies        Message[]  @relation("MessageReply")

  @@index([zaloMsgId])
  // Powers /search/messages: filter by conversation, sort by sentAt desc
  @@index([conversationId, sentAt(sort: Desc)])
  // Feature 0033 — friend aggregates: chatting-count query filters by
  // `(conversation_id, sender_type='contact', sent_at >= NOW() - 7d)`. The
  // existing `(conversationId, sentAt)` index does not cover senderType so
  // Postgres still has to read rows it would otherwise skip. This composite
  // makes the inner join on conversations → messages an index-only scan
  // for inbound traffic in the active window.
  @@index([conversationId, senderType, sentAt(sort: Desc)])
  // Feature 0031 — eager loading of reply chain in GET messages projection
  @@index([replyToMessageId])
  @@map("messages")
}

// Appointment scheduled for a contact
model Appointment {
  id              String   @id @default(uuid())
  orgId           String   @map("org_id")
  contactId       String   @map("contact_id")
  assignedUserId  String?  @map("assigned_user_id")
  appointmentDate DateTime @map("appointment_date")
  appointmentTime String?  @map("appointment_time")
  type            String?
  status          String   @default("scheduled") // scheduled, completed, cancelled, no_show
  notes           String?
  reminderSent    Boolean  @default(false) @map("reminder_sent")
  createdAt       DateTime @default(now()) @map("created_at")

  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contact      Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  assignedUser User?        @relation(fields: [assignedUserId], references: [id])

  @@map("appointments")
}

// Audit trail for user actions
model ActivityLog {
  id         String   @id @default(uuid())
  orgId      String   @map("org_id")
  userId     String?  @map("user_id")
  action     String
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  details    Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User?        @relation(fields: [userId], references: [id])

  @@map("activity_logs")
}

// Daily messaging statistics per user per Zalo account
model DailyMessageStat {
  id                String   @id @default(uuid())
  orgId             String   @map("org_id")
  userId            String   @map("user_id")
  zaloAccountId     String   @map("zalo_account_id")
  statDate          DateTime @map("stat_date") @db.Date
  messagesSent      Int      @default(0) @map("messages_sent")
  messagesReceived  Int      @default(0) @map("messages_received")
  messagesUnread    Int      @default(0) @map("messages_unread")
  messagesUnreplied Int      @default(0) @map("messages_unreplied")
  avgResponseTime   Int?     @map("avg_response_time_seconds")

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  zaloAccount ZaloAccount  @relation(fields: [zaloAccountId], references: [id], onDelete: Cascade)

  @@unique([userId, zaloAccountId, statDate])
  @@map("daily_message_stats")
}

// Encrypted or plain key-value settings per org
model AppSetting {
  id             String   @id @default(uuid())
  orgId          String   @map("org_id")
  settingKey     String   @map("setting_key")
  valuePlain     String?  @map("value_plain")
  valueEncrypted Bytes?   @map("value_encrypted")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, settingKey])
  @@map("app_settings")
}

// Sales order linked to a contact (and optionally a conversation)
model Order {
  id              String   @id @default(uuid())
  orgId           String   @map("org_id")
  contactId       String   @map("contact_id")
  createdByUserId String   @map("created_by_user_id")
  conversationId  String?  @map("conversation_id")
  orderCode       String   @map("order_code")
  totalAmount     Float    @map("total_amount")
  status          String   @default("new") // new, confirmed, paid, shipped, completed, cancelled
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  org          Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contact      Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)
  createdBy    User          @relation("CreatedOrders", fields: [createdByUserId], references: [id])
  conversation Conversation? @relation(fields: [conversationId], references: [id])

  @@map("orders")
}

// Reusable message templates ("quick replies") — feature 0004
model QuickReply {
  id              String   @id @default(uuid())
  orgId           String   @map("org_id")
  createdByUserId String   @map("created_by_user_id")
  shortcut        String   // lowercase a-z0-9_-, 2-20 chars
  content         String
  scope           String   @default("user") // "user" (private) or "org" (shared)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy User         @relation("CreatedQuickReplies", fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([orgId, scope])
  @@index([createdByUserId])
  @@map("quick_replies")
}

// Auto-reply / out-of-office rule per Zalo account (feature 0005)
model AutoReplyRule {
  id              String   @id @default(uuid())
  zaloAccountId   String   @unique @map("zalo_account_id")
  enabled         Boolean  @default(true)
  // Active window — when a message arrives OUTSIDE this window, auto-reply fires.
  // daysOfWeek is a 7-bit mask: bit 0 = Sun, bit 1 = Mon, ..., bit 6 = Sat
  // Default 0b0111110 = 62 = Mon..Fri.
  daysOfWeek      Int      @default(62) @map("days_of_week")
  startMinute     Int      @default(480) @map("start_minute") // 08:00
  endMinute       Int      @default(1080) @map("end_minute")  // 18:00
  timezone        String   @default("Asia/Ho_Chi_Minh")
  message         String   // reply text — supports {{contactName}} / {{firstName}}
  cooldownMinutes Int      @default(240) @map("cooldown_minutes")
  lastTriggeredAt DateTime? @map("last_triggered_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  zaloAccount ZaloAccount        @relation(fields: [zaloAccountId], references: [id], onDelete: Cascade)
  history     AutoReplyHistory[]

  @@map("auto_reply_rules")
}

// Cooldown ledger — one row per (rule, contact) tracking the last auto-reply
model AutoReplyHistory {
  id         String   @id @default(uuid())
  ruleId     String   @map("rule_id")
  contactUid String   @map("contact_uid")
  sentAt     DateTime @default(now()) @map("sent_at")

  rule AutoReplyRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@unique([ruleId, contactUid])
  @@index([sentAt])
  @@map("auto_reply_history")
}

// Bulk message campaign — feature 0008
// A campaign owns a snapshot of contacts (CampaignTarget rows) and is driven
// by a cron worker that picks running campaigns and sends to pending targets
// with a randomized delay between messages.
model Campaign {
  id              String   @id @default(uuid())
  orgId           String   @map("org_id")
  createdByUserId String   @map("created_by_user_id")
  zaloAccountId   String   @map("zalo_account_id")
  name            String
  message         String   // text, 1-2000 chars; supports {{contactName}} / {{firstName}}
  status          String   @default("draft") // draft|scheduled|running|paused|completed|cancelled
  scheduledAt     DateTime? @map("scheduled_at") // null = send immediately on start
  startedAt       DateTime? @map("started_at")
  completedAt     DateTime? @map("completed_at")
  filterSnapshot  Json     @default("{}") @map("filter_snapshot") // {status?:[], source?:[], tags?:[]}
  totalTargets    Int      @default(0) @map("total_targets")
  sentCount       Int      @default(0) @map("sent_count")
  failedCount     Int      @default(0) @map("failed_count")
  skippedCount    Int      @default(0) @map("skipped_count")
  isDeleted       Boolean  @default(false) @map("is_deleted")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  org         Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy   User             @relation("CreatedCampaigns", fields: [createdByUserId], references: [id])
  zaloAccount ZaloAccount      @relation(fields: [zaloAccountId], references: [id])
  targets     CampaignTarget[]

  @@index([status, scheduledAt])
  @@index([orgId, createdAt(sort: Desc)])
  @@map("campaigns")
}

// One row per (campaign, contact). Worker iterates over pending and updates
// to sent/failed/skipped.
model CampaignTarget {
  id           String    @id @default(uuid())
  campaignId   String    @map("campaign_id")
  contactId    String    @map("contact_id")
  status       String    @default("pending") // pending|sent|failed|skipped
  errorMessage String?   @map("error_message")
  sentAt       DateTime? @map("sent_at")
  attemptCount Int       @default(0) @map("attempt_count")
  createdAt    DateTime  @default(now()) @map("created_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact  Contact  @relation(fields: [contactId], references: [id])

  @@unique([campaignId, contactId])
  @@index([campaignId, status])
  @@map("campaign_targets")
}

// Keyword-based auto-tagging rule — feature 0009
// When an inbound (contact-sent) message in a 1-1 thread contains any of the
// configured keywords, this rule's actions are applied to the contact:
// add a tag, set/upgrade the pipeline status, or assign to a user.
model KeywordRule {
  id             String   @id @default(uuid())
  orgId          String   @map("org_id")
  name           String
  enabled        Boolean  @default(true)
  keywords       Json     // string[] — substring match, case-insensitive
  addTag         String?  @map("add_tag")
  setStatus      String?  @map("set_status") // pipeline enum
  assignToUserId String?  @map("assign_to_user_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  org          Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  assignToUser User?                @relation("KeywordRuleAssign", fields: [assignToUserId], references: [id])
  triggers     KeywordRuleTrigger[]

  @@index([orgId, enabled])
  @@map("keyword_rules")
}

// Ledger so the same rule doesn't fire twice on the same conversation
model KeywordRuleTrigger {
  id             String   @id @default(uuid())
  ruleId         String   @map("rule_id")
  conversationId String   @map("conversation_id")
  contactId      String   @map("contact_id")
  matchedKeyword String   @map("matched_keyword")
  triggeredAt    DateTime @default(now()) @map("triggered_at")

  rule KeywordRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@unique([ruleId, conversationId])
  @@index([triggeredAt])
  @@map("keyword_rule_triggers")
}

// Internal sales notes pinned to a conversation — feature 0010
// Visible to everyone with read access on the Zalo account; the customer
// never sees these. Author + admin can edit/delete.
model ConversationNote {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  authorId       String   @map("author_id")
  content        String
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  author       User         @relation("ConversationNotes", fields: [authorId], references: [id])

  @@index([conversationId, createdAt(sort: Desc)])
  @@map("conversation_notes")
}

// Outbound webhook delivery attempts — feature 0014
// Persists every call to the org's webhook URL so admins can debug + replay.
model WebhookDelivery {
  id             String   @id @default(uuid())
  orgId          String   @map("org_id")
  event          String
  url            String
  payload        String   @db.Text
  signature      String?
  responseStatus Int?     @map("response_status")
  durationMs     Int?     @map("duration_ms")
  errorMessage   String?  @map("error_message")
  createdAt      DateTime @default(now()) @map("created_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, createdAt(sort: Desc)])
  @@map("webhook_deliveries")
}

// ─── Feature 0015 — Pinned conversations ─────────────────────────────────────
// Org-shared "pinned to top" flag for a conversation. One row per conversation
// (uniqueness enforced via @unique on conversationId). Anyone in the org who
// has access to the underlying Zalo account sees the same pinned ordering.

model PinnedConversation {
  id             String   @id @default(uuid())
  orgId          String   @map("org_id")
  zaloAccountId  String   @map("zalo_account_id")
  conversationId String   @unique @map("conversation_id")
  pinnedAt       DateTime @default(now()) @map("pinned_at")

  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  zaloAccount  ZaloAccount  @relation(fields: [zaloAccountId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([orgId, pinnedAt(sort: Desc)])
  @@map("pinned_conversations")
}

// ─────────────────────────────────────────────────────────────────────────────
// Feature 0016 — User preferences KV store
// Per-user JSON key-value store for UI preferences (theme, density, sidebar
// state, last-used filters, ...). Values are arbitrary JSON; the key allowlist
// lives in user-preference-routes.ts so we don't need a migration for every
// new client-side preference.
// ─────────────────────────────────────────────────────────────────────────────
model UserPreference {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  key       String
  value     Json     @default("null")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@map("user_preferences")
}

// ─────────────────────────────────────────────────────────────────────────────
// Feature 0018 — Duplicate contact detection + merge
// A DuplicateGroup is a set of contact IDs (≥ 2) that the scanner believes are
// the same person. Admins resolve each group by either MERGING (one contact
// becomes primary, the rest get `mergedIntoId` set + FK-rewrite to primary) or
// DISMISSING (false positive — skip this exact set on future scans).
//
// `contactIdsHash` (sha1 of sorted ids) acts as the idempotency key so a rescan
// of the same population doesn't create a duplicate group row. Hash of the
// dismissed set is also kept so future rescans can skip known-false-positives.
// ─────────────────────────────────────────────────────────────────────────────
model DuplicateGroup {
  id               String    @id @default(uuid())
  orgId            String    @map("org_id")
  level            String    // 'phone_exact' | 'zaloUid_exact' | 'name_fuzzy'
  confidence       Float
  contactIds       Json      // string[] — sorted ascending, length >= 2
  contactIdsHash   String    @map("contact_ids_hash") // sha1 of sorted ids
  status           String    @default("pending") // pending | merged | dismissed
  primaryContactId String?   @map("primary_contact_id")
  resolvedByUserId String?   @map("resolved_by_user_id")
  resolvedAt       DateTime? @map("resolved_at")
  detectedAt       DateTime  @default(now()) @map("detected_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, contactIdsHash])
  @@index([orgId, status, detectedAt(sort: Desc)])
  @@map("duplicate_groups")
}

// ─── Feature 0020 — Friendship lifecycle ─────────────────────────────────────
// Sale dùng zca-js để tra Zalo UID từ phone rồi gửi lời mời kết bạn. Vòng đời
// queued → looking_up → sent → accepted | declined | timeout | error |
// cancelled là `FriendshipAttempt`. Khi accepted, một `Friend` row được tạo
// (unique theo `(zaloAccountId, zaloUid)`) làm bằng chứng quan hệ đã kết nối.
// Worker xử lý batch mỗi 30s, listener bắt sự kiện `friend_event` từ zca-js.
// Mỗi cặp (contactId, zaloAccountId) có tối đa MỘT attempt active tại một
// thời điểm — xem BR-0005 trong SPEC.
// ─────────────────────────────────────────────────────────────────────────────

model FriendshipAttempt {
  id              String    @id @default(uuid())
  orgId           String    @map("org_id")
  contactId       String    @map("contact_id")
  zaloAccountId   String    @map("zalo_account_id")
  createdByUserId String?   @map("created_by_user_id")
  state           String    @default("queued") // queued|looking_up|sent|accepted|declined|timeout|error|cancelled
  zaloUidFound    String?   @map("zalo_uid_found")
  requestMsg      String?   @map("request_msg")
  resolvedMsg     String?   @map("resolved_msg")
  errorCode       String?   @map("error_code")
  errorDetail     String?   @map("error_detail")
  queuedAt        DateTime  @default(now()) @map("queued_at")
  lookedUpAt      DateTime? @map("looked_up_at")
  sentAt          DateTime? @map("sent_at")
  decidedAt       DateTime? @map("decided_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  contact     Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  zaloAccount ZaloAccount @relation(fields: [zaloAccountId], references: [id], onDelete: Cascade)
  createdBy   User?       @relation("CreatedFriendshipAttempts", fields: [createdByUserId], references: [id])
  friend      Friend?

  @@index([orgId, state])
  @@index([zaloAccountId, state])
  @@index([contactId, zaloAccountId, state])
  @@map("friendship_attempts")
}

model Friend {
  id            String   @id @default(uuid())
  orgId         String   @map("org_id")
  zaloAccountId String   @map("zalo_account_id")
  zaloUid       String   @map("zalo_uid")
  contactId     String?  @map("contact_id")
  attemptId     String?  @unique @map("attempt_id")
  displayName   String?  @map("display_name")
  avatarUrl     String?  @map("avatar_url")
  createdAt     DateTime @default(now()) @map("created_at")

  zaloAccount ZaloAccount        @relation(fields: [zaloAccountId], references: [id], onDelete: Cascade)
  contact     Contact?           @relation(fields: [contactId], references: [id])
  attempt     FriendshipAttempt? @relation(fields: [attemptId], references: [id])

  @@unique([zaloAccountId, zaloUid])
  @@index([orgId, createdAt(sort: Desc)])
  @@map("friends")
}

// ─── Feature 0019 — CRM tags ──────────────────────────────────────────────────
// Relational tag model. The ContactTag junction is the single source of truth
// for tag membership; the legacy Contact.tags Json column was dropped in
// Phase C.
//
// `managedBy='zalo_sync'` tags are read-only and pulled from Zalo. Users cannot
// rename, archive, or delete them through the regular CRUD endpoints.
// Case-folding: `normalizedName = name.trim().normalize('NFC').toLowerCase()`
// — "VIP" and "vip" collide on `(orgId, normalizedName)`.
// ─────────────────────────────────────────────────────────────────────────────

model CrmTag {
  id                String    @id @default(uuid())
  orgId             String    @map("org_id")
  name              String    // hiển thị, giữ nguyên case
  normalizedName    String    @map("normalized_name") // lowercase, trimmed
  color             String    @default("#9E9E9E") // hex #RRGGBB
  emoji             String?
  description       String?
  groupId           String?   @map("group_id")
  managedBy         String?   @map("managed_by") // null | 'zalo_sync'
  sourceZaloLabelId String?   @map("source_zalo_label_id") // FK soft → ZaloLabel.id
  order             Int       @default(0)
  isActive          Boolean   @default(true) @map("is_active")
  usageCount        Int       @default(0) @map("usage_count")
  archivedAt        DateTime? @map("archived_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  org          Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  group        CrmTagGroup?  @relation(fields: [groupId], references: [id], onDelete: SetNull)
  contactTags  ContactTag[]

  @@unique([orgId, normalizedName])
  @@index([orgId, isActive, archivedAt])
  @@index([orgId, groupId])
  @@map("crm_tags")
}

model CrmTagGroup {
  id            String    @id @default(uuid())
  orgId         String    @map("org_id")
  name          String
  managedBy     String?   @map("managed_by") // null | 'zalo_sync'
  zaloAccountId String?   @map("zalo_account_id") // set when group mirrors a Zalo account's labels
  order         Int       @default(0)
  archivedAt    DateTime? @map("archived_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  zaloAccount ZaloAccount? @relation(fields: [zaloAccountId], references: [id], onDelete: SetNull)
  tags        CrmTag[]

  @@unique([orgId, name])
  @@map("crm_tag_groups")
}

model ZaloLabel {
  id            String   @id @default(uuid())
  orgId         String   @map("org_id")
  zaloAccountId String   @map("zalo_account_id")
  zaloLabelId   String   @map("zalo_label_id") // numeric id from Zalo SDK
  textKey       String   @map("text_key")
  text          String
  color         String
  emoji         String?
  offset        Int      @default(0)
  version       Int      @default(0)
  conversations Json     @default("[]") // string[] of external thread ids
  createTime    BigInt?  @map("create_time")
  syncedAt      DateTime @default(now()) @map("synced_at")

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  zaloAccount ZaloAccount  @relation(fields: [zaloAccountId], references: [id], onDelete: Cascade)

  @@unique([zaloAccountId, zaloLabelId])
  @@index([orgId])
  @@map("zalo_labels")
}

model ContactTag {
  contactId     String   @map("contact_id")
  tagId         String   @map("tag_id")
  addedAt       DateTime @default(now()) @map("added_at")
  addedByUserId String?  @map("added_by_user_id")

  contact     Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag         CrmTag  @relation(fields: [tagId],     references: [id], onDelete: Cascade)
  addedByUser User?   @relation("ContactTagsAdded", fields: [addedByUserId], references: [id], onDelete: SetNull)

  @@id([contactId, tagId])
  @@index([tagId])
  @@map("contact_tags")
}

// ─── Feature 0021 — Message reactions ────────────────────────────────────────
// One row per (message, reactor). BR-0004/0005: each reactor can hold AT MOST
// one reaction per message at a time — same emoji again means "toggle off"
// (row deleted), different emoji means override (emoji column updated).
//
// `reactorSource` discriminates the side that produced the row:
//   - "crm"  → outbound from CRM, reactorId = User.id (UUID)
//   - "zalo" → inbound from zca-js listener, reactorId = Zalo UID (string)
//
// Two rows CAN coexist for the same react when self-listen fires (EC-0004):
// one CRM-side row with reactorId = user.id, one Zalo-side row with
// reactorId = zaloAccount.zaloUid. The compound key (messageId, reactorId)
// never collides because the two id namespaces (UUID vs Zalo UID) don't
// overlap. FE dedupes the counter on (reactorSource, reactorId).
//
// `emoji` stores the displayable character ("❤️", "👍", …) directly so FE
// can render it without a lookup. For unknown rType > 6 (custom reactions —
// BR-0010 / EC-0007), we persist `"custom:<rType>"`; rendering is fallback.
// ─────────────────────────────────────────────────────────────────────────────
model MessageReaction {
  id            String   @id @default(uuid())
  messageId     String   @map("message_id")
  reactorId     String   @map("reactor_id")
  reactorSource String   @default("crm") @map("reactor_source")
  reactorName   String?  @map("reactor_name")
  emoji         String
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, reactorId])
  @@index([messageId])
  @@map("message_reactions")
}

// ─── Feature 0037 — Workflow automation engine (phase 1) ─────────────────────
// Single trigger type (`inbound_message`) + four step types
// (`send_message`, `add_tag`, `assign_user`, `wait`) executed sequentially.
// A cron-style worker (workflow-runner) ticks every 60s, picks any
// WorkflowExecution whose `nextStepDueAt` is in the past, and advances the
// step pointer. 24h re-trigger cooldown enforced at evaluator level.
// Future phases (Phase 2): time-based triggers, branching, more step types.
// ─────────────────────────────────────────────────────────────────────────────
model WorkflowDefinition {
  id          String   @id @default(uuid())
  orgId       String   @map("org_id")
  name        String
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  // { type: 'inbound_message', messageMatch?, contactStatus?, isFirstInbound? }
  trigger     Json
  // [{ type: 'send_message'|'add_tag'|'assign_user'|'wait', delayMinutes, ... }]
  steps       Json
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  org        Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  executions WorkflowExecution[]

  @@index([orgId, isActive])
  @@map("workflow_definitions")
}

model WorkflowExecution {
  id              String    @id @default(uuid())
  orgId           String    @map("org_id")
  workflowId      String    @map("workflow_id")
  contactId       String    @map("contact_id")
  conversationId  String?   @map("conversation_id")
  // running | completed | failed | cancelled
  status          String    @default("running")
  currentStepIdx  Int       @default(0) @map("current_step_idx")
  nextStepDueAt   DateTime? @map("next_step_due_at")
  // [{ idx, status: 'ok'|'failed'|'skipped', ranAt: ISO, error? }]
  stepLog         Json      @default("[]") @map("step_log")
  startedAt       DateTime  @default(now()) @map("started_at")
  completedAt     DateTime? @map("completed_at")

  org      Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  workflow WorkflowDefinition @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  contact  Contact            @relation(fields: [contactId], references: [id], onDelete: Cascade)

  // Worker scan: WHERE status='running' AND nextStepDueAt <= NOW().
  @@index([orgId, status, nextStepDueAt])
  // Cooldown re-trigger lookup: (workflow, contact) ordered by startedAt desc.
  @@index([workflowId, contactId, startedAt(sort: Desc)])
  @@map("workflow_executions")
}

// ─── Feature 0036 — AI reply suggestions (multi-provider, BYOK) ──────────────
// Per-org AI configuration. We hold an encrypted (AES-256-GCM) provider API
// key plus model + system prompt. The plaintext key NEVER leaves the encrypt-
// config helper — every read decrypts on the fly. See encrypt-config.ts.
// Suggestion CONTENT is never persisted; only metadata in AiSuggestionLog.
// ─────────────────────────────────────────────────────────────────────────────
model AiConfig {
  id                   String   @id @default(uuid())
  orgId                String   @unique @map("org_id")
  // 'anthropic' | 'openai' | 'gemini' | 'qwen' | 'kimi' | 'ollama'
  provider             String
  // AES-256-GCM ciphertext (hex). Empty for providers that need no key (Ollama).
  apiKeyCipher         String   @default("") @map("api_key_cipher")
  apiKeyIv             String   @default("") @map("api_key_iv")
  apiKeyTag            String   @default("") @map("api_key_tag")
  // Optional override URL (Ollama local endpoint, self-hosted OpenAI-compat, …)
  apiEndpoint          String?  @map("api_endpoint")
  model                String
  systemPrompt         String?  @map("system_prompt")
  enabled              Boolean  @default(false)
  maxSuggestionsPerDay Int      @default(1000) @map("max_suggestions_per_day")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("ai_configs")
}

model AiSuggestionLog {
  id             String   @id @default(uuid())
  orgId          String   @map("org_id")
  userId         String   @map("user_id")
  conversationId String   @map("conversation_id")
  // The inbound message that triggered the suggestion (msg the rep is replying to).
  triggerMsgId   String   @map("trigger_msg_id")
  provider       String
  model          String
  tokensIn       Int      @map("tokens_in")
  tokensOut      Int      @map("tokens_out")
  // USD estimate (best-effort from per-provider rate table).
  costEstimate   Float    @map("cost_estimate")
  latencyMs      Int      @map("latency_ms")
  // Null on success. On failure: 'provider_401' | 'provider_5xx' | 'timeout' | …
  errorCode      String?  @map("error_code")
  createdAt      DateTime @default(now()) @map("created_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  // Daily quota count + usage aggregation (orgId + createdAt range).
  @@index([orgId, createdAt])
  // Per-user hourly soft cap (BR-0016).
  @@index([userId, createdAt])
  @@map("ai_suggestion_logs")
}
