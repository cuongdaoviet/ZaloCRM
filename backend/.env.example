PORT=3000
NODE_ENV=production
APP_URL=https://your-domain.com

JWT_SECRET=          # openssl rand -hex 32
ENCRYPTION_KEY=      # openssl rand -hex 16

DB_USER=crmuser
DB_PASSWORD=         # your password
DB_NAME=zalocrm
DATABASE_URL=postgresql://crmuser:password@db:5432/zalocrm

UPLOAD_DIR=/var/lib/zalo-crm/files

# Feature 0036 + 0038 — shared crypto master key for AES-256-GCM
# encryption of provider API keys (0036) and integration config blobs
# (0038). 32 bytes hex (64 chars). NEVER commit a real value.
# Generate: openssl rand -hex 32
AI_CONFIG_MASTER_KEY=    # openssl rand -hex 32
# Feature 0038 — Google Sheets OAuth (Sheets connector).
# Create at https://console.cloud.google.com/apis/credentials with scope
# "https://www.googleapis.com/auth/spreadsheets".
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Must match an "Authorised redirect URI" entry in the same OAuth client.
GOOGLE_OAUTH_REDIRECT_URI=https://your-domain.com/api/v1/integrations/oauth/google/callback
