# === Zalo Sales CRM ===
PORT=3000
NODE_ENV=production
APP_URL=https://zalo.ngay.top

# Security — generate strong random values for production
JWT_SECRET=
ENCRYPTION_KEY=

# Database
DB_USER=crmuser
DB_PASSWORD=
DB_NAME=zalocrm
DATABASE_URL=postgresql://crmuser:password@db:5432/zalocrm

# Storage
UPLOAD_DIR=/var/lib/zalo-crm/files

# === Object storage (feature 0027 — MinIO attachment mirror) ===
# Override `MINIO_ROOT_PASSWORD` for production deployments.
# `S3_ENDPOINT` is the URL the backend uses to talk to MinIO (use the
# docker DNS name when running via docker-compose). `S3_PUBLIC_URL` is
# what the browser sees in <img src> tags — must be reachable from the
# user's network (e.g. https://files.example.com on prod).
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_URL=http://localhost:9000
S3_BUCKET=zalocrm-attachments
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# === Feature 0033 — friend aggregates ===
# Window (in days) used by GET /api/v1/friends/stats to count "actively
# chatting" friends. A friend counts as active if any inbound message from
# them exists in the last N days. Default 7 — increase for slower segments.
FRIEND_ACTIVE_WINDOW_DAYS=7

# AI (Phase 6)
# AI_PROVIDER=claude
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
