# === Zalo Sales CRM ===
PORT=3000
NODE_ENV=production
APP_URL=https://zalo.ngay.top

# Security — generate strong random values for production.
# Feature 0046 BR-0004: boot guard refuses to start in production when
# JWT_SECRET is unset, equals the dev placeholder, or is shorter than
# 32 chars. Generate with:  openssl rand -base64 48
JWT_SECRET=
ENCRYPTION_KEY=

# Database
DB_USER=crmuser
DB_PASSWORD=
DB_NAME=zalocrm
DATABASE_URL=postgresql://crmuser:password@db:5432/zalocrm

# Storage
UPLOAD_DIR=/var/lib/zalo-crm/files

# === Object storage (feature 0027 — MinIO attachment mirror) ===
# Feature 0046 BR-0008/BR-0010 — no defaults. docker-compose refuses to
# start when these are unset, so a deploy can't accidentally ship with
# `minioadmin/minioadmin` credentials.
#
#   MINIO_ROOT_USER:      pick a non-default identifier, e.g.
#                         "zalocrm_minio_$(openssl rand -hex 4)"
#   MINIO_ROOT_PASSWORD:  openssl rand -base64 24
#
# `S3_ENDPOINT` is the URL the backend uses to talk to MinIO over the
# docker bridge. `S3_PUBLIC_URL` is what the browser sees in <img src>.
# After Feature 0046 the public URL points at the nginx reverse proxy
# (`/attachments/...`) instead of the raw MinIO port.
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_URL=https://your-domain.com/attachments
S3_BUCKET=zalocrm-attachments
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1

# === Feature 0033 — friend aggregates ===
# Window (in days) used by GET /api/v1/friends/stats to count "actively
# chatting" friends. A friend counts as active if any inbound message from
# them exists in the last N days. Default 7 — increase for slower segments.
FRIEND_ACTIVE_WINDOW_DAYS=7

# AI (Phase 6)
# AI_PROVIDER=claude
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
